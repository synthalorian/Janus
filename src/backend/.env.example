# Janus Backend Environment Variables

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/janus

# Server
PORT=3001
NODE_ENV=development
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Feature flags
JANUS_BOTS_ENABLED=false
JANUS_OVERSIGHT_ENABLED=false

# Future: JWT Secret (for auth)
# JWT_SECRET=your-secret-key-here

# Future: Redis (for caching)
# REDIS_URL=redis://localhost:6379
