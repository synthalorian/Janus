{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  },
  "include": [
    "src/index.ts",
    "src/config.ts",
    "src/routes/api.ts",
    "src/routes/auth.ts",
    "src/auth/**/*.ts",
    "src/contracts/**/*.ts",
    "src/socket/**/*.ts",
    "src/db/**/*.ts",
    "src/store/**/*.ts",
    "src/types/**/*.ts",
    "src/nlp/analyzer.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "src/bots/**",
    "src/oversight/**",
    "src/routes/bots.ts",
    "src/routes/oversight.ts",
    "src/routes/spawn.ts",
    "src/db/schema.auth.ts",
    "src/db/schema.bots.ts"
  ]
}
