{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "strictNullChecks": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  },
  "include": [
    "src/index.ts",
    "src/config.ts",
    "src/routes/api.ts",
    "src/routes/auth.ts",
    "src/routes/orchestration.ts",
    "src/auth/**/*.ts",
    "src/contracts/**/*.ts",
    "src/socket/**/*.ts",
    "src/db/**/*.ts",
    "src/store/**/*.ts",
    "src/types/**/*.ts",
    "src/nlp/analyzer.ts",
    "src/orchestration/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
