<% content_for :header_title, "OVERSIGHT" %>
<% content_for :title, "Oversight — Janus" %>

<div style="display:flex;flex-direction:column;gap:20px;">
  <!-- Stats -->
  <div class="stats-grid" style="grid-template-columns:repeat(4, 1fr);">
    <div class="stat-card">
      <div class="stat-value" style="font-size:24px;"><%= @stats["pending"] || 0 %></div>
      <div class="stat-label">Pending</div>
    </div>
    <div class="stat-card">
      <div class="stat-value" style="font-size:24px;color:var(--success);"><%= @stats["approved"] || 0 %></div>
      <div class="stat-label">Approved</div>
    </div>
    <div class="stat-card">
      <div class="stat-value" style="font-size:24px;color:var(--error);"><%= @stats["rejected"] || 0 %></div>
      <div class="stat-label">Rejected</div>
    </div>
    <div class="stat-card">
      <div class="stat-value" style="font-size:24px;color:var(--accent-secondary);"><%= @stats["total"] || 0 %></div>
      <div class="stat-label">Total Actions</div>
    </div>
  </div>

  <!-- Pending Actions -->
  <div>
    <div class="section-title">Pending Review</div>
    <% if @pending.any? %>
      <div class="cards-grid">
        <% @pending.each do |action| %>
          <div class="janus-card" style="padding:16px;">
            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px;">
              <span style="font-size:12px;font-weight:600;color:var(--text-primary);"><%= action["actionType"] %></span>
              <span class="badge badge-warning"><%= action["oversightLevel"] %></span>
            </div>
            <p style="font-size:11px;color:var(--text-secondary);margin:0 0 8px;"><%= action["description"] %></p>
            <div style="font-size:10px;color:var(--text-muted);font-family:var(--font-mono);">
              by <%= action["agentName"] %> · risk: <%= (action.dig("risk", "score") || 0).round(2) %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="janus-card" style="text-align:center;padding:40px 20px;">
        <div style="font-size:36px;margin-bottom:8px;opacity:0.5;">⚖️</div>
        <p style="color:var(--text-muted);margin:0;font-size:13px;">No pending oversight actions</p>
      </div>
    <% end %>
  </div>

  <!-- Board -->
  <% if @board %>
    <div class="janus-card">
      <div class="janus-card-header">
        <span class="janus-card-title">🏛️ Oversight Board</span>
      </div>
      <div style="display:flex;gap:16px;font-size:12px;color:var(--text-secondary);">
        <div><span style="color:var(--text-muted);">Quorum:</span> <%= @board["quorum"] %></div>
        <div><span style="color:var(--text-muted);">Threshold:</span> <%= @board["approvalThreshold"] %></div>
        <div><span style="color:var(--text-muted);">Members:</span> <%= (@board["members"] || []).length %></div>
      </div>
      <% if @board["members"].is_a?(Array) && @board["members"].any? %>
        <div style="margin-top:12px;padding-top:12px;border-top:1px solid var(--border-color);">
          <% @board["members"].each do |m| %>
            <span class="badge badge-primary" style="margin-right:4px;"><%= m["name"] %> (<%= m["role"] %>)</span>
          <% end %>
        </div>
      <% end %>
    </div>
  <% end %>
</div>