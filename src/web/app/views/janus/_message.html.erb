<div class="chat-message <%= message["authorType"] == "human" ? "user" : "ai" %>">
  <div style="font-size:9px;font-weight:600;text-transform:uppercase;letter-spacing:0.06em;margin-bottom:4px;opacity:0.7;font-family:var(--font-mono);">
    <%= message["authorName"] || message["authorId"] %>
    <% if message["authorType"] == "ai" %><span style="color:var(--accent-cyan);"> ● AI</span><% end %>
  </div>
  <div><%= simple_format h(message["content"]), {}, wrapper_tag: "div" %></div>
  <div class="chat-timestamp"><%= message["timestamp"] ? time_ago_in_words(Time.parse(message["timestamp"])) + " ago" : "" %></div>
</div>